{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the local micro-skills platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "credits": { "type": "number", "description": "TimeCoins balance. Starts at 2." },
        "skillsOffered": { "type": "array", "items": { "type": "string" } },
        "skillsNeeded": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number", "description": "Average rating (thumbs up %)" },
        "reviewsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "displayName", "email", "credits", "createdAt", "role"]
    },
    "SkillRequest": {
      "title": "SkillRequest",
      "description": "A request or offer for a micro-skill.",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["offer", "request"] },
        "status": { "type": "string", "enum": ["open", "matched", "completed", "cancelled"] },
        "matchedWithUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "authorName", "title", "description", "type", "status", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two users who matched on a request.",
      "type": "object",
      "properties": {
        "requestId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestId", "participants", "updatedAt", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderUid", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/SkillRequest" },
      "description": "Skill exchange requests and offers"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat sessions between matched users"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a chat session"
    }
  }
}
